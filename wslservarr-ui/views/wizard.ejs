<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>WSLServarr Setup Wizard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css" />
  <style>
    .wizard-container { max-width: 900px; margin: 40px auto; padding: 0 24px; }
    .wizard-card { background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 10px; padding: 24px; }
    .stepper { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; margin: 20px 0 24px; }
    .step-pill { padding: 10px 8px; border: 1px solid var(--border); border-radius: 6px; font-size: .8rem; text-align: center; color: var(--text-secondary); }
    .step-pill.active { border-color: var(--accent); color: var(--accent); }
    .step-panel { display: none; }
    .step-panel.active { display: block; }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; }
    .actions { margin-top: 20px; display: flex; justify-content: space-between; gap: 10px; }
    .app-card { padding: 14px; border: 1px solid var(--border); border-radius: 6px; margin-bottom: 10px; }
    .check-ok { color: #22c55e; }
    .check-bad { color: #f87171; }
    .muted { color: var(--text-secondary); }
    .summary { font-size: .9rem; background: var(--bg-tertiary); padding: 12px; border-radius: 6px; border: 1px solid var(--border); }
    .inline { display: flex; align-items: center; gap: 8px; }
  </style>
</head>
<body>
  <div class="wizard-container">
    <h1>❯ wslservarr</h1>
    <p class="subtitle">Initial setup wizard</p>

    <% if (message) { %><div class="msg ok">✓ <%= message %></div><% } %>
    <% if (error) { %><div class="msg err">⚠ <%= error %></div><% } %>

    <div class="wizard-card">
      <div class="stepper">
        <div class="step-pill active" data-step-pill="1">1. Environment</div>
        <div class="step-pill" data-step-pill="2">2. Storage</div>
        <div class="step-pill" data-step-pill="3">3. Services</div>
        <div class="step-pill" data-step-pill="4">4. Runtime</div>
        <div class="step-pill" data-step-pill="5">5. Review</div>
      </div>

      <form method="post" action="/wizard" id="wizardForm">
        <div class="step-panel active" data-step="1">
          <h2>Environment checks</h2>
          <p class="muted">Validate required mounts and Docker availability before continuing.</p>
          <div id="checksArea">
            <div class="inline"><span class="<%= checks.dockerSocket ? 'check-ok' : 'check-bad' %>"><%= checks.dockerSocket ? '●' : '●' %></span> Docker socket: <strong><%= checks.dockerSocket ? 'present' : 'missing' %></strong></div>
            <div class="inline"><span class="<%= checks.dockerResponsive ? 'check-ok' : 'check-bad' %>">●</span> Docker API: <strong><%= checks.dockerResponsive ? 'responsive' : 'unavailable' %></strong></div>
            <div class="inline"><span class="<%= checks.configMount ? 'check-ok' : 'check-bad' %>">●</span> /mnt/config mount</div>
            <div class="inline"><span class="<%= checks.mediaMount ? 'check-ok' : 'check-bad' %>">●</span> /mnt/media mount</div>
            <div class="inline"><span class="<%= checks.downloadsMount ? 'check-ok' : 'check-bad' %>">●</span> /mnt/downloads mount</div>
          </div>
          <p class="muted" id="checkErrorText"><%= checks.dockerError || '' %></p>
        </div>

        <div class="step-panel" data-step="2">
          <h2>Storage mapping</h2>
          <p class="muted">Use mounted WSL paths. Defaults match the installer.</p>
          <div class="grid-3">
            <div><label>Config Root</label><input name="configRoot" value="<%= config.paths?.configRoot || '/mnt/config' %>" /></div>
            <div><label>Media Root</label><input name="mediaRoot" value="<%= config.paths.mediaRoot %>" /></div>
            <div><label>Downloads Root</label><input name="downloadsRoot" value="<%= config.paths.downloadsRoot %>" /></div>
          </div>
          <div class="grid-2" style="margin-top:12px;">
            <div><label>Sonarr Media Path</label><input name="sonarrMediaPath" value="<%= config.sonarr.tvRoot %>" /></div>
            <div><label>Radarr Media Path</label><input name="radarrMediaPath" value="<%= config.radarr.movieRoot %>" /></div>
          </div>
        </div>

        <div class="step-panel" data-step="3">
          <h2>Select services</h2>
          <p class="muted">Pick at least one service and set host ports.</p>
          <label class="app-card inline"><input type="checkbox" name="sonarrEnabled" <%= config.sonarr.enabled ? 'checked' : '' %> /> 📺 Sonarr</label>
          <div class="grid-3" style="margin-bottom:12px;">
            <div><label>Sonarr Port</label><input name="sonarrPort" value="<%= config.sonarr.port %>" /></div>
            <div><label>Sonarr URL</label><input value="http://sonarr:8989" disabled /></div>
          </div>

          <label class="app-card inline"><input type="checkbox" name="radarrEnabled" <%= config.radarr.enabled ? 'checked' : '' %> /> 🎬 Radarr</label>
          <div class="grid-3" style="margin-bottom:12px;">
            <div><label>Radarr Port</label><input name="radarrPort" value="<%= config.radarr.port %>" /></div>
            <div><label>Radarr URL</label><input value="http://radarr:7878" disabled /></div>
          </div>

          <label class="app-card inline"><input type="checkbox" name="sabnzbdEnabled" <%= config.sabnzbd.enabled ? 'checked' : '' %> /> 🔽 SABnzbd</label>
          <div class="grid-3">
            <div><label>SABnzbd Port</label><input name="sabnzbdPort" value="<%= config.sabnzbd.port %>" /></div>
            <div><label>TV Category</label><input name="tvCategory" value="<%= config.sabnzbd.tvCategory %>" /></div>
            <div><label>Movie Category</label><input name="movieCategory" value="<%= config.sabnzbd.movieCategory %>" /></div>
          </div>
        </div>

        <div class="step-panel" data-step="4">
          <h2>Runtime defaults</h2>
          <p class="muted">These are written to container environment variables.</p>
          <div class="grid-3">
            <div><label>Timezone</label><input name="timezone" value="<%= config.runtime.timezone %>" /></div>
            <div><label>PUID</label><input name="puid" value="<%= config.runtime.puid %>" /></div>
            <div><label>PGID</label><input name="pgid" value="<%= config.runtime.pgid %>" /></div>
          </div>
        </div>

        <div class="step-panel" data-step="5">
          <h2>Review & apply</h2>
          <p class="muted">Validate inputs, save wizard config, and optionally install selected apps now.</p>
          <div id="validationBox" class="summary">No validation run yet.</div>
          <div style="margin-top:12px;" class="summary" id="summaryBox"></div>
          <label class="inline" style="margin-top:12px;">
            <input type="checkbox" name="installNow" checked /> Install selected services immediately after setup
          </label>
        </div>

        <div class="actions">
          <button type="button" class="secondary" id="backBtn">← back</button>
          <div style="display:flex; gap:10px;">
            <button type="button" class="secondary" id="validateBtn" style="display:none;">validate</button>
            <button type="button" id="nextBtn">next →</button>
            <button type="submit" id="finishBtn" style="display:none;">✓ complete setup</button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <script>
    let currentStep = 1;
    const maxStep = 5;

    function panel(step) { return document.querySelector(`.step-panel[data-step="${step}"]`); }
    function pill(step) { return document.querySelector(`.step-pill[data-step-pill="${step}"]`); }

    function showStep(step) {
      currentStep = Math.min(maxStep, Math.max(1, step));
      for (let i = 1; i <= maxStep; i++) {
        panel(i).classList.toggle('active', i === currentStep);
        pill(i).classList.toggle('active', i === currentStep);
      }
      document.getElementById('backBtn').disabled = currentStep === 1;
      document.getElementById('nextBtn').style.display = currentStep === maxStep ? 'none' : 'inline-block';
      document.getElementById('finishBtn').style.display = currentStep === maxStep ? 'inline-block' : 'none';
      document.getElementById('validateBtn').style.display = currentStep === maxStep ? 'inline-block' : 'none';
      if (currentStep === 5) renderSummary();
    }

    function getFormDataObject() {
      const form = document.getElementById('wizardForm');
      const fd = new FormData(form);
      return Object.fromEntries(fd.entries());
    }

    async function validateWizard() {
      const obj = getFormDataObject();
      const res = await fetch('/api/wizard/validate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(obj)
      });
      const data = await res.json();
      const box = document.getElementById('validationBox');
      if (!data.ok) {
        box.innerHTML = `<strong>Validation failed</strong><br>${(data.errors || []).join('<br>')}`;
        box.style.borderColor = '#ef4444';
      } else {
        const warns = (data.warnings || []).length ? `<br><br><strong>Warnings</strong><br>${data.warnings.join('<br>')}` : '';
        box.innerHTML = `<strong>Validation passed</strong>${warns}`;
        box.style.borderColor = '#22c55e';
      }
      return data.ok;
    }

    function renderSummary() {
      const obj = getFormDataObject();
      const enabled = ['sonarrEnabled','radarrEnabled','sabnzbdEnabled'].filter(k => obj[k] === 'on').map(k => k.replace('Enabled',''));
      document.getElementById('summaryBox').innerHTML = `
        <strong>Services:</strong> ${enabled.join(', ') || 'none'}<br>
        <strong>Paths:</strong> config=${obj.configRoot || '/mnt/config'}, media=${obj.mediaRoot || '/mnt/media'}, downloads=${obj.downloadsRoot || '/mnt/downloads'}<br>
        <strong>Ports:</strong> sonarr=${obj.sonarrPort || '8989'}, radarr=${obj.radarrPort || '7878'}, sabnzbd=${obj.sabnzbdPort || '8080'}<br>
        <strong>Runtime:</strong> TZ=${obj.timezone || 'America/New_York'}, PUID=${obj.puid || '1000'}, PGID=${obj.pgid || '1000'}
      `;
    }

    document.getElementById('nextBtn').addEventListener('click', async () => {
      if (currentStep === 5) return;
      if (currentStep === 1) {
        const failed = [...document.querySelectorAll('#checksArea .check-bad')].length > 0;
        if (failed && !confirm('Some checks failed. Continue anyway?')) return;
      }
      showStep(currentStep + 1);
    });
    document.getElementById('backBtn').addEventListener('click', () => showStep(currentStep - 1));
    document.getElementById('validateBtn').addEventListener('click', validateWizard);

    document.getElementById('wizardForm').addEventListener('submit', async (e) => {
      const ok = await validateWizard();
      if (!ok) e.preventDefault();
    });

    showStep(1);
  </script>
</body>
</html>
