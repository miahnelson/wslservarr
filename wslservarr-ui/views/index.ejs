<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>WSLServarr UI</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <div class="container">
    <!-- Header -->
    <h1>❯ wslservarr</h1>
    <p class="subtitle">distributed media orchestration platform</p>

    <!-- Messages -->
    <% if (message) { %>
      <div class="msg ok">✓ <%= message %></div>
    <% } %>
    <% if (error) { %>
      <div class="msg err">⚠ <%= error %></div>
    <% } %>

    <!-- Container Status -->
    <div class="card">
      <h2>⚙ Container Runtime</h2>
      <p class="card-subtitle">Current deployment state and health</p>
      <table>
        <thead>
          <tr>
            <th>Service</th>
            <th>Status</th>
            <th>Image</th>
            <th>Controls</th>
          </tr>
        </thead>
        <tbody>
          <% containers.forEach(c => { %>
            <tr>
              <td><strong><%= c.name %></strong></td>
              <td>
                <% if (c.status === 'running') { %>
                  <span class="status-running">● running</span>
                <% } else if (c.status === 'missing') { %>
                  <span class="status-missing">○ not deployed</span>
                <% } else { %>
                  <span class="status-stopped">● stopped</span>
                <% } %>
              </td>
              <td><code class="small"><%= c.image || '-' %></code></td>
              <td class="actions">
                <button class="secondary small-btn" onclick="containerAction('<%= c.name %>','start')" title="Start service">start</button>
                <button class="secondary small-btn" onclick="containerAction('<%= c.name %>','stop')" title="Stop service">stop</button>
                <button class="secondary small-btn" onclick="containerAction('<%= c.name %>','restart')" title="Restart service">↻</button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Configuration Form -->
    <form method="post" action="/config" class="card">
      <!-- Shared Settings -->
      <div class="shared-settings">
        <h3>🌐 Shared Configuration</h3>
        <p class="card-subtitle">Common paths and runtime parameters</p>
        <div class="grid-2">
          <div>
            <label>Media Root (WSL Path)</label>
            <input name="mediaRoot" value="<%= config.paths.mediaRoot %>" placeholder="/mnt/media" />
            <label>Downloads Root (WSL Path)</label>
            <input name="downloadsRoot" value="<%= config.paths.downloadsRoot %>" placeholder="/mnt/downloads" />
          </div>
          <div>
            <label>Timezone</label>
            <input name="timezone" value="<%= config.runtime.timezone %>" placeholder="America/New_York" />
            <label>PUID:PGID</label>
            <div style="display: flex; gap: 12px;">
              <input name="puid" value="<%= config.runtime.puid %>" placeholder="1000" style="flex: 1;" />
              <input name="pgid" value="<%= config.runtime.pgid %>" placeholder="1000" style="flex: 1;" />
            </div>
          </div>
        </div>
      </div>

      <!-- Sonarr Section -->
      <div class="container-section">
        <div class="section-header" onclick="toggleSection(this)">
          <input type="checkbox" name="sonarrEnabled" <%= config.sonarr.enabled ? 'checked' : '' %> />
          <div>
            <h3>📺 Sonarr</h3>
            <p class="small" style="margin: 4px 0 0 0;">TV show management & automation</p>
          </div>
          <span class="status-badge <%= config.sonarr.enabled ? 'enabled' : 'disabled' %>">
            <%= config.sonarr.enabled ? 'enabled' : 'disabled' %>
          </span>
          <span class="toggle-arrow">▼</span>
        </div>
        <div class="section-content">
          <div class="grid-2">
            <div>
              <label>Service URL</label>
              <input name="sonarrUrl" value="<%= config.sonarr.url %>" placeholder="http://sonarr:8989" />
              <label>API Key</label>
              <input name="sonarrApiKey" value="<%= config.sonarr.apiKey %>" type="password" placeholder="••••••••••••••••" />
            </div>
            <div>
              <label>Port Binding</label>
              <input name="sonarrPort" value="<%= config.sonarr.port %>" placeholder="8989" />
              <label>Media Path (TV)</label>
              <input name="tvRoot" value="<%= config.sonarr.tvRoot %>" placeholder="/mnt/media/tv" />
            </div>
          </div>
          <div class="actions">
            <button formaction="/test/sonarr" formmethod="post" class="secondary" type="submit">→ test connection</button>
            <button formaction="/apply" formmethod="post" class="success" type="submit">✓ apply config</button>
          </div>
        </div>
      </div>

      <!-- Radarr Section -->
      <div class="container-section">
        <div class="section-header" onclick="toggleSection(this)">
          <input type="checkbox" name="radarrEnabled" <%= config.radarr.enabled ? 'checked' : '' %> />
          <div>
            <h3>🎬 Radarr</h3>
            <p class="small" style="margin: 4px 0 0 0;">Movie management & acquisition</p>
          </div>
          <span class="status-badge <%= config.radarr.enabled ? 'enabled' : 'disabled' %>">
            <%= config.radarr.enabled ? 'enabled' : 'disabled' %>
          </span>
          <span class="toggle-arrow">▼</span>
        </div>
        <div class="section-content">
          <div class="grid-2">
            <div>
              <label>Service URL</label>
              <input name="radarrUrl" value="<%= config.radarr.url %>" placeholder="http://radarr:7878" />
              <label>API Key</label>
              <input name="radarrApiKey" value="<%= config.radarr.apiKey %>" type="password" placeholder="••••••••••••••••" />
            </div>
            <div>
              <label>Port Binding</label>
              <input name="radarrPort" value="<%= config.radarr.port %>" placeholder="7878" />
              <label>Media Path (Movies)</label>
              <input name="movieRoot" value="<%= config.radarr.movieRoot %>" placeholder="/mnt/media/movies" />
            </div>
          </div>
          <div class="actions">
            <button formaction="/test/radarr" formmethod="post" class="secondary" type="submit">→ test connection</button>
            <button formaction="/apply" formmethod="post" class="success" type="submit">✓ apply config</button>
          </div>
        </div>
      </div>

      <!-- SABnzbd Section -->
      <div class="container-section">
        <div class="section-header" onclick="toggleSection(this)">
          <input type="checkbox" name="sabnzbdEnabled" <%= config.sabnzbd.enabled ? 'checked' : '' %> />
          <div>
            <h3>🔽 SABnzbd</h3>
            <p class="small" style="margin: 4px 0 0 0;">Usenet binary downloader</p>
          </div>
          <span class="status-badge <%= config.sabnzbd.enabled ? 'enabled' : 'disabled' %>">
            <%= config.sabnzbd.enabled ? 'enabled' : 'disabled' %>
          </span>
          <span class="toggle-arrow">▼</span>
        </div>
        <div class="section-content">
          <div class="grid-2">
            <div>
              <label>Service URL</label>
              <input name="sabUrl" value="<%= config.sabnzbd.url %>" placeholder="http://sabnzbd:8080" />
              <label>API Key</label>
              <input name="sabApiKey" value="<%= config.sabnzbd.apiKey %>" type="password" placeholder="••••••••••••••••" />
            </div>
            <div>
              <label>Port Binding</label>
              <input name="sabPort" value="<%= config.sabnzbd.port %>" placeholder="8080" />
              <label>Categories</label>
              <div style="display: flex; gap: 12px;">
                <input name="tvCategory" value="<%= config.sabnzbd.tvCategory %>" placeholder="tv" style="flex: 1;" />
                <input name="movieCategory" value="<%= config.sabnzbd.movieCategory %>" placeholder="movies" style="flex: 1;" />
              </div>
            </div>
          </div>
          <div class="actions">
            <button formaction="/test/sabnzbd" formmethod="post" class="secondary" type="submit">→ test connection</button>
          </div>
        </div>
      </div>

      <!-- Save Button -->
      <button type="submit" style="width: 100%; margin-top: 24px; padding: 14px; font-size: 1rem;">💾 save all settings</button>
    </form>

    <!-- Deploy Section -->
    <form method="post" action="/install/apps" class="card" id="deployForm">
      <h2>⚡ Deploy Services</h2>
      <p class="card-subtitle">Install & configure enabled services</p>
      <button type="submit" style="width: 100%; padding: 14px; font-size: 1rem;" id="deployBtn">→ deploy checked services</button>
      <p class="small" style="margin-top: 10px;">Status: <span id="deployStatus">idle</span></p>
      <pre id="deployLog" style="margin-top: 10px; max-height: 260px; overflow: auto; background: var(--bg-tertiary); border: 1px solid var(--border); border-radius: 6px; padding: 12px; font-size: 0.8rem; white-space: pre-wrap;">No deployment output yet.</pre>
    </form>

    <form method="post" action="/wizard/restart" class="card" onsubmit="return confirm('Re-open setup wizard? This lets you re-run initial setup.');">
      <h2>🧭 Setup Wizard</h2>
      <p class="card-subtitle">Need to run initial setup again? Launch the wizard.</p>
      <button type="submit" class="secondary" style="width: 100%; padding: 14px; font-size: 1rem;">⟲ start setup wizard</button>
    </form>

    <!-- Compose Editor -->
    <form method="post" action="/compose" class="card">
      <h2>🧩 Compose YAML</h2>
      <p class="card-subtitle">Review and edit the app deployment yaml stored in the UI config.</p>
      <label>compose.apps.yml</label>
      <textarea name="composeYaml" rows="18" style="width: 100%; font-family: 'Fira Code', monospace; font-size: 0.85rem;"><%= config.composeYaml %></textarea>
      <button type="submit" style="width: 100%; margin-top: 12px; padding: 14px; font-size: 1rem;">💾 save yaml</button>
    </form>

    <!-- Footer -->
    <div style="text-align: center; color: var(--text-secondary); margin-top: 40px; padding-top: 20px; border-top: 1px solid var(--border); font-size: 0.9rem;">
      <p>wslservarr v1.0 • distributed orchestration framework<br>
      <span style="color: var(--accent);">❯</span> engineered with precision
      </p>
    </div>
  </div>

  <script>
    let deployEventSource = null;

    function renderDeployState(state) {
      if (!state) return;
      const status = document.getElementById('deployStatus');
      const log = document.getElementById('deployLog');
      const btn = document.getElementById('deployBtn');

      if (state.running) {
        status.textContent = 'running';
        btn.disabled = true;
      } else if (state.success === true) {
        status.textContent = 'completed';
        btn.disabled = false;
      } else if (state.success === false) {
        status.textContent = 'failed';
        btn.disabled = false;
      } else {
        status.textContent = 'idle';
        btn.disabled = false;
      }

      if (Array.isArray(state.logs) && state.logs.length > 0) {
        log.textContent = state.logs.join('\n');
        log.scrollTop = log.scrollHeight;
      }
    }

    function connectDeployStream() {
      if (deployEventSource) return;
      deployEventSource = new EventSource('/api/install/apps/stream');
      deployEventSource.onmessage = (evt) => {
        try {
          const payload = JSON.parse(evt.data || '{}');
          if (payload.state) renderDeployState(payload.state);
        } catch (_) {
          // ignore malformed payloads
        }
      };
      deployEventSource.onerror = () => {
        // Keep page functional even if stream temporarily drops.
      };
    }

    function toggleSection(header) {
      const content = header.nextElementSibling;
      const arrow = header.querySelector('.toggle-arrow');
      content.classList.toggle('open');
      arrow.classList.toggle('open');
    }

    async function containerAction(name, action) {
      const r = await fetch(`/container/${name}/${action}`, { method: 'POST' });
      if (!r.ok) {
        const body = await r.json().catch(() => ({}));
        alert(`[${action.toUpperCase()}] ${body.error || 'Action failed'}`);
        return;
      }
      location.reload();
    }

    // Update status badge on checkbox change
    document.querySelectorAll('.section-header input[type="checkbox"]').forEach(cb => {
      cb.addEventListener('change', function() {
        const header = this.closest('.section-header');
        const badge = header.querySelector('.status-badge');
        const isChecked = this.checked;
        badge.textContent = isChecked ? 'enabled' : 'disabled';
        badge.className = isChecked ? 'status-badge enabled' : 'status-badge disabled';
      });
    });

    // Add keyboard shortcut for save
    document.addEventListener('keydown', function(e) {
      if ((e.ctrlKey || e.metaKey) && e.key === 's') {
        e.preventDefault();
        document.querySelector('form').dispatchEvent(new Event('submit'));
      }
    });

    document.getElementById('deployForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      connectDeployStream();

      const status = document.getElementById('deployStatus');
      status.textContent = 'starting...';

      const res = await fetch('/api/install/apps/start', { method: 'POST' });
      const body = await res.json().catch(() => ({}));
      if (!res.ok || !body.ok) {
        status.textContent = 'failed to start';
        alert(body.error || 'Failed to start deployment');
        if (body.state) renderDeployState(body.state);
        return;
      }

      if (body.state) renderDeployState(body.state);
    });

    connectDeployStream();
  </script>
</body>
</html>
